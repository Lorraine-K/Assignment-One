import numpy as np
import matplotlib.pyplot as plt
from scipy.stats import linregress

# Black-Scholes true values (from Exercise 1)
BS_call = 10.4506
BS_put = 7.0740

def euler_european_options(S0, K, r, sigma, T, M, m):
    """
    Price European call and put using Euler scheme (path-dependent simulation).
    
    Parameters:
    S0: Initial stock price
    K: Strike price
    r: Risk-free rate
    sigma: Volatility
    T: Time to maturity
    M: Number of simulations
    m: Number of time steps
    
    Returns:
    call_price, call_se, put_price, put_se
    """
    dt = T / m
    call_payoffs = np.zeros(M)
    put_payoffs = np.zeros(M)
    
    for i in range(M):
        S = S0
        # Generate path using Euler scheme
        for j in range(m):
            Z = np.random.normal(0, 1)
            S = S * (1 + r * dt + sigma * np.sqrt(dt) * Z)
        # Record terminal price
        call_payoffs[i] = max(S - K, 0)
        put_payoffs[i] = max(K - S, 0)
    
    df = np.exp(-r * T)
    call_mean, call_var = np.mean(call_payoffs), np.var(call_payoffs, ddof=1)
    put_mean, put_var = np.mean(put_payoffs), np.var(put_payoffs, ddof=1)
    
    return df*call_mean, df*np.sqrt(call_var/M), df*put_mean, df*np.sqrt(put_var/M)

# ============================================================================
# Part 1: Fix m=100, vary M
# ============================================================================
print("=" * 80)
print("PART 1: Fixed m=100, varying M")
print("=" * 80)

np.random.seed(42)
m_fixed = 100
M_values_part1 = [10**2, 10**3, 10**4, 10**5]
results_part1 = []

print(f"{'M':<12} {'Call Price':<15} {'Call SE':<15} {'Put Price':<15} {'Put SE':<15}")
print("-" * 80)

for M in M_values_part1:
    call_price, call_se, put_price, put_se = euler_european_options(100, 100, 0.05, 0.2, 1, M, m_fixed)
    results_part1.append({'M': M, 'call_price': call_price, 'call_se': call_se, 
                          'put_price': put_price, 'put_se': put_se})
    print(f"{M:<12} {call_price:<15.6f} {call_se:<15.6f} {put_price:<15.6f} {put_se:<15.6f}")

# Verify SE ∝ 1/√M
print("\n" + "-" * 80)
print("Verifying SE ∝ 1/√M:")
print("-" * 80)
print(f"{'M':<12} {'Call SE':<15} {'Call SE * √M':<20} {'Put SE':<15} {'Put SE * √M':<20}")
print("-" * 80)

for res in results_part1:
    M = res['M']
    call_se_times_sqrtM = res['call_se'] * np.sqrt(M)
    put_se_times_sqrtM = res['put_se'] * np.sqrt(M)
    print(f"{M:<12} {res['call_se']:<15.6f} {call_se_times_sqrtM:<20.6f} {res['put_se']:<15.6f} {put_se_times_sqrtM:<20.6f}")

# Log-log regression for convergence rate
log_M = np.log10(M_values_part1)
log_call_se = np.log10([res['call_se'] for res in results_part1])
log_put_se = np.log10([res['put_se'] for res in results_part1])

slope_call, intercept_call, r_value_call, p_value_call, std_err_call = linregress(log_M, log_call_se)
slope_put, intercept_put, r_value_put, p_value_put, std_err_put = linregress(log_M, log_put_se)

print("\n" + "-" * 80)
print(f"Call SE slope: {slope_call:.4f} (should be ~ -0.5 for 1/√M)")
print(f"Put SE slope:  {slope_put:.4f} (should be ~ -0.5 for 1/√M)")
print("-" * 80)

# ============================================================================
# Part 2: Fix M=10^5, vary m
# ============================================================================
print("\n" + "=" * 80)
print("PART 2: Fixed M=10^5, varying m")
print("=" * 80)

np.random.seed(42)
M_fixed = 10**5
m_values_part2 = [10, 50, 100, 500, 1000]
results_part2 = []

print(f"{'m':<12} {'Call Price':<15} {'Call Error':<15} {'Put Price':<15} {'Put Error':<15}")
print("-" * 80)

for m in m_values_part2:
    call_price, call_se, put_price, put_se = euler_european_options(100, 100, 0.05, 0.2, 1, M_fixed, m)
    call_error = abs(call_price - BS_call)
    put_error = abs(put_price - BS_put)
    results_part2.append({'m': m, 'call_price': call_price, 'call_error': call_error,
                          'put_price': put_price, 'put_error': put_error, 'call_se': call_se, 'put_se': put_se})
    print(f"{m:<12} {call_price:<15.6f} {call_error:<15.6f} {put_price:<15.6f} {put_error:<15.6f}")

# Check for systematic bias
print("\n" + "-" * 80)
print("Analyzing bias (error vs m):")
print("-" * 80)
print(f"{'m':<12} {'Call Error':<15} {'Error Change from prev':<25}")
print("-" * 80)

prev_error = None
for res in results_part2:
    if prev_error is not None:
        change = res['call_error'] - prev_error
        print(f"{res['m']:<12} {res['call_error']:<15.6f} {change:<25.6f}")
    else:
        print(f"{res['m']:<12} {res['call_error']:<15.6f} {'N/A':<25}")
    prev_error = res['call_error']

