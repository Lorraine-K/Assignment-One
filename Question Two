print("\nQUESTION 3")
print("-" * 60)

results3 = []

for m in m_values:

    for M in M_values:

        price, se = euler_mc(M, m)

        error = abs(price - VBS)

        results3.append([M, m, price, error])

df3 = pd.DataFrame(results3,
                   columns=["M", "m", "Price", "Absolute Error"])

print(df3)

# ====================================================
# Question 4
# ====================================================

print("\nQUESTION 4")
print("-" * 60)

C = 10**7

print(f"Budget = {C:,} operations")

best_pair = None
best_error = np.inf

for m in [10, 50, 100, 500, 1000]:

    M = C // m

    price, se = euler_mc(int(M), m)

    error = abs(price - VBS)

    if error < best_error:

        best_error = error
        best_pair = (int(M), m, price, error)

print("\nSuggested Optimal Allocation")

print(f"M* = {best_pair[0]:,}")
print(f"m* = {best_pair[1]}")
print(f"Estimated Price = {best_pair[2]:.6f}")
print(f"Absolute Error = {best_pair[3]:.6f}")
