# Part 3: Convergence table showing error as function of M and m
# ============================================================================
print("\n" + "=" * 80)
print("PART 3: Convergence Table - Error |V̂_M - V_BS|")
print("=" * 80)

np.random.seed(42)
M_values_part3 = [10**2, 10**3, 10**4, 10**5]
m_values_part3 = [10, 50, 100, 500, 1000]

