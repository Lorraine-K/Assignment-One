print("\nQUESTION 2")
print("-" * 60)

m_values = [10, 50, 100, 500, 1000]
M = 10**5

results2 = []

for m in m_values:

    price, se = euler_mc(M, m)

    results2.append([m, price])

df2 = pd.DataFrame(results2,
