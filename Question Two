import numpy as np
import pandas as pd
from scipy.stats import norm

# -----------------------------
# Parameters
# -----------------------------
S0 = 100
K = 100
r = 0.05
sigma = 0.2
T = 1

np.random.seed(2026)

# -----------------------------
# Black-Scholes Call Price
# -----------------------------
def black_scholes_call(S0, K, r, sigma, T):
    d1 = (np.log(S0 / K) + (r + 0.5 * sigma**2) * T) / (sigma * np.sqrt(T))
    d2 = d1 - sigma * np.sqrt(T)

    return S0 * norm.cdf(d1) - K * np.exp(-r * T) * norm.cdf(d2)

VBS = black_scholes_call(S0, K, r, sigma, T)

print(f"Black-Scholes Price = {VBS:.6f}")

# -----------------------------
# Euler Monte Carlo Simulator
# -----------------------------
def euler_mc(M, m):

    dt = T / m

    S = np.full(M, S0)

    for _ in range(m):

        Z = np.random.randn(M)

        S = S + r * S * dt + sigma * S * np.sqrt(dt) * Z

    payoff = np.exp(-r * T) * np.maximum(S - K, 0)

    price = np.mean(payoff)

    se = np.std(payoff, ddof=1) / np.sqrt(M)

    return price, se

# ====================================================
# Question 1
# ====================================================

print("\nQUESTION 1")
print("-" * 60)

M_values = [10**2, 10**3, 10**4, 10**5]
m = 100

results1 = []

for M in M_values:

    price, se = euler_mc(M, m)

    results1.append([M, price, se])

df1 = pd.DataFrame(results1,
                   columns=["M", "Price", "Standard Error"])

print(df1)

print("\nObservation:")
print("Standard error decreases approximately as 1/sqrt(M).")

